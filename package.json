{
  "name": "yt-dl-desktop",
  "version": "1.0.2",
  "description": "",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.yt-dl-desktop.app",
    "productName": "YTDlDesktop",
    "compression": "normal",
    "afterPack": "build/afterPack.cjs",
    "electronLanguages": ["es", "en"],
    "files": [
      "src/**/*",
      "package.json",
      "build/**/*",
      "!node_modules",
      "!.github",
      "!dist",
      "!bin"
    ],
    "win": {
      "target": "portable",
      "icon": null,
      "signAndEditExecutable": false
    },
    "portable": {
      "splashImage": null
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.2.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
